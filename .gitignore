# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg

# ── Virtual environments ─────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Jupyter Notebooks ────────────────────────────────────────
# Strip outputs before committing; keep the .ipynb files themselves
.ipynb_checkpoints/

# ── ML / AI Artifacts ────────────────────────────────────────
# Model weights (potentially hundreds of MB)
*.pt
*.pth
*.onnx
*.tflite
*.engine
*.torchscript
*.pb

# Training runs (generated by Ultralytics)
runs/
wandb/
mlruns/
lightning_logs/

# ── Dataset ──────────────────────────────────────────────────
# Raw and processed data (too large for Git; use DVC or Kaggle)
data/
datasets/
*.zip
*.tar.gz
*.tar

# Fused images and labels (auto-generated by pipeline)
llvip_fusion_yolov8/

# Offline metrics output
offline_metrics/

# ── Secrets / Credentials ────────────────────────────────────
.env
.env.*
secrets.yaml
kaggle.json
*.key

# ── IDEs ─────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── OS ───────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Cache ────────────────────────────────────────────────────
.cache/
*.cache
